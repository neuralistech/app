# Theme session secret (generate a random string for production)
SESSION_SECRET=change-me-in-production

# Formspree endpoint for contact form (get from formspree.io)
FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Public Cloudinary cloud name (not a secret; used for CDN image URLs)
# Prefer setting this in hosting env; falls back to config.json if unset at build time.
CLOUDINARY_CLOUD_NAME=

# Node environment
NODE_ENV=production
